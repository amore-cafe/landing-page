---
import IndexLayout from "@layouts/indexLayout.astro";
import { Image } from "astro:assets";
import AmoreLogo from "@assets/images/amore-logo-rect.png";
---

<script>
  document
    .querySelector("#back-button")
    ?.addEventListener("click", () => history.back());

  // Form handling
  const form = document.querySelector("#reservation-form") as HTMLFormElement;
  const reservationType = document.querySelector(
    "#reservation-type"
  ) as HTMLSelectElement;
  const playstationSection = document.querySelector("#playstation-section");
  const tableSection = document.querySelector("#table-section");

  // Toggle sections based on reservation type
  reservationType?.addEventListener("change", (e) => {
    const value = (e.target as HTMLSelectElement).value;
    if (value === "playstation") {
      playstationSection?.classList.remove("hidden");
      tableSection?.classList.add("hidden");
    } else if (value === "table") {
      playstationSection?.classList.add("hidden");
      tableSection?.classList.remove("hidden");
    } else {
      playstationSection?.classList.add("hidden");
      tableSection?.classList.add("hidden");
    }
  });

  // Form submission
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // Create WhatsApp message
    const phoneNumber = "916351560030";
    
    let message = `🎉 *New Reservation Request*\n\n`;
    message += `📅 *Date:* ${data.date}\n`;
    message += `🕐 *Time:* ${data.time}\n`;
    message += `📝 *Type:* ${data.type === 'playstation' ? 'PlayStation Gaming' : 'Table'}\n`;
    
    if (data.type === "table") {
      message += `👥 *Number of Guests:* ${data.guests}\n`;
    } else {
      message += `🎮 *Console:* ${data.console}\n`;
      message += `⏰ *Duration:* ${data.duration} hours\n`;
      message += `👥 *Number of Players:* ${data.players}\n`;
    }
    
    message += `\n👤 *Contact Details:*\n`;
    message += `Name: ${data.name}\n`;
    message += `Phone: ${data.phone}\n`;
    if (data.email) message += `Email: ${data.email}\n`;
    if (data.notes) message += `\n📌 *Special Requests:* ${data.notes}`;

    const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
    window.open(whatsappUrl, "_blank");
  });
</script>

<IndexLayout>
  <main class="reservations-page flex flex-col min-h-screen bg-accent">
    <!-- Header -->
    <header
      class="header-section flex h-24 p-4 items-center gap-2 shrink-0 bg-dark-accent"
    >
      <button class="cursor-pointer" id="back-button">
        <svg
          width="113"
          height="16"
          viewBox="0 0 113 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M0.292893 7.29288C-0.0976333 7.68341 -0.0976334 8.31657 0.292892 8.7071L6.65685 15.0711C7.04738 15.4616 7.68054 15.4616 8.07107 15.0711C8.46159 14.6805 8.46159 14.0474 8.07107 13.6568L2.41421 7.99999L8.07107 2.34314C8.46159 1.95261 8.46159 1.31945 8.07107 0.928923C7.68054 0.538399 7.04738 0.538399 6.65685 0.928923L0.292893 7.29288ZM113 8L113 7L1 6.99999L1 7.99999L1 8.99999L113 9L113 8Z"
            fill="white"></path>
        </svg>
      </button>
      <a href="/" class="hidden md:inline">
        <Image src={AmoreLogo} alt="Amore Cafe" width={210} />
      </a>
      <svg
        class="hidden md:inline"
        width="49"
        height="2"
        viewBox="0 0 49 2"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M48 -4.19629e-06L49 -4.28372e-06L49 2L48 2L48 0.999996L48 -4.19629e-06ZM0 1L-8.74228e-08 0L48 -4.19629e-06L48 0.999996L48 2L8.74228e-08 2L0 1Z"
          fill="white"></path>
      </svg>
      <h1
        class="menu-title text-accent font-agrandir text-5xl font-light leading-none"
      >
        Reservations
      </h1>
      <div class="header-divider w-full h-px bg-accent"></div>
    </header>

    <!-- Reservation Form -->
    <section class="reservation-section flex-1 p-8 md:p-12 max-w-4xl mx-auto w-full">
      <div class="form-container bg-white rounded-lg shadow-lg p-8">
        <h2 class="text-3xl font-agrandir font-light mb-6 text-dark-accent">
          Reserve Your Experience
        </h2>
        <p class="text-gray-600 mb-8 font-inter">
          Book a table for dining or reserve a PlayStation gaming session. We'll
          confirm your reservation via WhatsApp.
        </p>

        <form id="reservation-form" class="space-y-6">
          <!-- Reservation Type -->
          <div>
            <label
              for="reservation-type"
              class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
            >
              Reservation Type <span class="text-red-500">*</span>
            </label>
            <select
              id="reservation-type"
              name="type"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
            >
              <option value="">Select type</option>
              <option value="table">Table Reservation</option>
              <option value="playstation">PlayStation Gaming</option>
            </select>
          </div>

          <!-- Date and Time -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label
                for="date"
                class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
              >
                Date <span class="text-red-500">*</span>
              </label>
              <input
                type="date"
                id="date"
                name="date"
                required
                min={new Date().toISOString().split("T")[0]}
                class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
              />
            </div>
            <div>
              <label
                for="time"
                class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
              >
                Time <span class="text-red-500">*</span>
              </label>
              <input
                type="time"
                id="time"
                name="time"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
              />
            </div>
          </div>

          <!-- Table Reservation Section -->
          <div id="table-section" class="hidden space-y-6">
            <div>
              <label
                for="guests"
                class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
              >
                Number of Guests <span class="text-red-500">*</span>
              </label>
              <input
                type="number"
                id="guests"
                name="guests"
                min="1"
                max="20"
                class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
                placeholder="Enter number of guests"
              />
            </div>
          </div>

          <!-- PlayStation Section -->
          <div id="playstation-section" class="hidden space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label
                  for="console"
                  class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
                >
                  Console Preference <span class="text-red-500">*</span>
                </label>
                <select
                  id="console"
                  name="console"
                  class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
                >
                  <option value="">Select console</option>
                  <option value="PS5">PlayStation 5</option>
                  <option value="PS4">PlayStation 4</option>
                  <option value="any">Any Available</option>
                </select>
              </div>
              <div>
                <label
                  for="duration"
                  class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
                >
                  Duration (hours) <span class="text-red-500">*</span>
                </label>
                <input
                  type="number"
                  id="duration"
                  name="duration"
                  min="1"
                  max="8"
                  class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
                  placeholder="1-8 hours"
                />
              </div>
            </div>
            <div>
              <label
                for="players"
                class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
              >
                Number of Players <span class="text-red-500">*</span>
              </label>
              <input
                type="number"
                id="players"
                name="players"
                min="1"
                max="4"
                class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
                placeholder="1-4 players"
              />
            </div>
          </div>

          <!-- Contact Information -->
          <div class="border-t pt-6 mt-6">
            <h3 class="text-xl font-agrandir font-light mb-4 text-dark-accent">
              Contact Information
            </h3>
            <div class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label
                    for="name"
                    class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
                  >
                    Full Name <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label
                    for="phone"
                    class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
                  >
                    Phone Number <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
                    placeholder="+91 XXXXX XXXXX"
                  />
                </div>
              </div>
              <div>
                <label
                  for="email"
                  class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
                >
                  Email (Optional)
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
                  placeholder="your.email@example.com"
                />
              </div>
              <div>
                <label
                  for="notes"
                  class="block text-sm font-medium text-gray-700 mb-2 font-agrandir"
                >
                  Special Requests (Optional)
                </label>
                <textarea
                  id="notes"
                  name="notes"
                  rows="3"
                  class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-dark-accent focus:border-transparent font-inter"
                  placeholder="Any special requests or dietary requirements?"
                ></textarea>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="flex justify-end pt-6">
            <button
              type="submit"
              class="px-8 py-4 bg-dark-accent text-white font-agrandir text-lg rounded-md hover:bg-opacity-90 transition-all hover:scale-105 active:scale-95 shadow-lg"
            >
              Send Reservation via WhatsApp
            </button>
          </div>
        </form>
      </div>

      <!-- Info Section -->
      <div class="mt-8 p-6 bg-white rounded-lg shadow-md">
        <h3 class="text-xl font-agrandir font-light mb-4 text-dark-accent">
          Reservation Policy
        </h3>
        <ul class="space-y-2 text-gray-600 font-inter text-sm">
          <li class="flex items-start">
            <span class="text-dark-accent mr-2">•</span>
            <span
              >Reservations are confirmed upon receiving a confirmation message
              from us.</span
            >
          </li>
          <li class="flex items-start">
            <span class="text-dark-accent mr-2">•</span>
            <span
              >Please arrive within 15 minutes of your reservation time.</span
            >
          </li>
          <li class="flex items-start">
            <span class="text-dark-accent mr-2">•</span>
            <span
              >PlayStation gaming sessions are charged per hour. Minimum 1 hour
              booking.</span
            >
          </li>
          <li class="flex items-start">
            <span class="text-dark-accent mr-2">•</span>
            <span
              >For cancellations or changes, please contact us at least 2 hours
              in advance.</span
            >
          </li>
        </ul>
      </div>
    </section>

    <!-- Bottom Navigation -->
    <nav
      class="bottom-navigation flex w-full h-16 px-4 justify-between items-center shrink-0 bg-dark-accent"
    >
      <a
        href="/"
        class="back-button flex h-8 px-0.5 justify-center items-center rounded-2xl"
      >
        <svg
          width="40"
          height="32"
          viewBox="0 0 40 32"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M1.29289 15.2929C0.902369 15.6834 0.902369 16.3166 1.29289 16.7071L7.65685 23.0711C8.04738 23.4616 8.68054 23.4616 9.07107 23.0711C9.46159 22.6805 9.46159 22.0474 9.07107 21.6569L3.41421 16L9.07107 10.3431C9.46159 9.95262 9.46159 9.31946 9.07107 8.92893C8.68054 8.53841 8.04738 8.53841 7.65685 8.92893L1.29289 15.2929ZM38 17C38.5523 17 39 16.5523 39 16C39 15.4477 38.5523 15 38 15V16V17ZM2 16L2 17L38 17V16V15L2 15L2 16Z"
            fill="white"></path>
        </svg>
      </a>
    </nav>
  </main>
</IndexLayout>

<style>
  .reservation-section {
    scroll-behavior: smooth;
  }

  @media (max-width: 768px) {
    .form-container {
      padding: 1.5rem;
    }
  }
</style>
