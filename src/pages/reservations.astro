---
import IndexLayout from "@layouts/indexLayout.astro";
import { Image } from "astro:assets";
import AmoreLogo from "@assets/images/amore-logo-rect.png";

const phoneNumber = "916351560030";
const message = "Hi! I'd like to make a reservation at Amore Cafe";
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
---

<script>
  document
    .querySelector("#back-button")
    ?.addEventListener("click", () => history.back());
</script>

<IndexLayout>
  <main class='reservations-page flex flex-col min-h-screen bg-accent'>
    <!-- Header -->
    <header
      class='header-section flex h-24 p-4 items-center gap-2 shrink-0 bg-dark-accent'>
      <button class='cursor-pointer' id='back-button'>
        <svg
          width='113'
          height='16'
          viewBox='0 0 113 16'
          fill='none'
          xmlns='http://www.w3.org/2000/svg'>
          <path
            d='M0.292893 7.29288C-0.0976333 7.68341 -0.0976334 8.31657 0.292892 8.7071L6.65685 15.0711C7.04738 15.4616 7.68054 15.4616 8.07107 15.0711C8.46159 14.6805 8.46159 14.0474 8.07107 13.6568L2.41421 7.99999L8.07107 2.34314C8.46159 1.95261 8.46159 1.31945 8.07107 0.928923C7.68054 0.538399 7.04738 0.538399 6.65685 0.928923L0.292893 7.29288ZM113 8L113 7L1 6.99999L1 7.99999L1 8.99999L113 9L113 8Z'
            fill='white'></path>
        </svg>
      </button>
      <a href='/' class='hidden md:inline'>
        <Image src={AmoreLogo} alt='Amore Cafe' width={210} />
      </a>
      <svg
        class='hidden md:inline'
        width='36'
        height='2'
        viewBox='0 0 49 2'
        fill='none'
        xmlns='http://www.w3.org/2000/svg'>
        <path
          d='M48 -4.19629e-06L49 -4.28372e-06L49 2L48 2L48 0.999996L48 -4.19629e-06ZM0 1L-8.74228e-08 0L48 -4.19629e-06L48 0.999996L48 2L8.74228e-08 2L0 1Z'
          fill='white'></path>
      </svg>
      <h1
        class='menu-title text-accent font-agrandir text-4xl md:text-5xl font-light leading-none'>
        Reservations
      </h1>
      <div class='header-divider w-full h-px bg-accent'></div>
    </header>

    <!-- Reservation Information -->
    <section
      class='reservation-section flex-1 p-8 md:p-16 max-w-7xl mx-auto w-full'>
      <!-- Main Content -->
      <div class='content-container space-y-12'>
        <!-- Hero Section -->
        <div class='text-center space-y-4 mb-12'>
          <h2
            class='text-4xl md:text-6xl font-agrandir font-light text-dark-accent'>
            Reserve Your Experience
          </h2>
          <p class='text-xl md:text-2xl text-gray-600 font-inter'>
            Book a table or gaming session at Amore Cafe
          </p>
        </div>

        <!-- Reservation Types -->
        <div class='grid md:grid-cols-2 gap-8'>
          <!-- Table Reservations -->
          <div
            class='reservation-card bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow'>
            <div
              class='icon-container bg-dark-accent bg-opacity-10 w-16 h-16 rounded-full flex items-center justify-center mb-6'>
              <svg
                class='w-8 h-8 text-dark-accent'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z'
                ></path>
              </svg>
            </div>
            <h3 class='text-2xl font-agrandir font-light mb-4 text-dark-accent'>
              Table Reservations
            </h3>
            <p class='text-gray-600 font-inter mb-6 leading-relaxed'>
              Reserve a table for your dining experience. Perfect for casual
              meetups, dates, or group gatherings.
            </p>
            <ul class='space-y-3 text-gray-600 font-inter text-sm mb-6'>
              <li class='flex items-start'>
                <span class='text-dark-accent mr-2'>✓</span>
                <span>Cozy and comfortable seating</span>
              </li>
              <li class='flex items-start'>
                <span class='text-dark-accent mr-2'>✓</span>
                <span>Indoor and outdoor options</span>
              </li>
              <li class='flex items-start'>
                <span class='text-dark-accent mr-2'>✓</span>
                <span>Groups up to 15 people</span>
              </li>
            </ul>
          </div>

          <!-- PlayStation Gaming -->
          <div
            class='reservation-card bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow'>
            <div
              class='icon-container bg-dark-accent bg-opacity-10 w-16 h-16 rounded-full flex items-center justify-center mb-6'>
              <svg
                class='w-8 h-8 text-dark-accent'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z'
                ></path>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M21 12a9 9 0 11-18 0 9 9 0 0118 0z'></path>
              </svg>
            </div>
            <h3 class='text-2xl font-agrandir font-light mb-4 text-dark-accent'>
              PlayStation Gaming
            </h3>
            <p class='text-gray-600 font-inter mb-6 leading-relaxed'>
              Book a gaming session with our PlayStation consoles. Enjoy the
              latest games while savoring delicious food and beverages.
            </p>
            <ul class='space-y-3 text-gray-600 font-inter text-sm mb-6'>
              <li class='flex items-start'>
                <span class='text-dark-accent mr-2'>✓</span>
                <span>PS4 & PS5 consoles available</span>
              </li>
              <li class='flex items-start'>
                <span class='text-dark-accent mr-2'>✓</span>
                <span>Popular games library</span>
              </li>
              <li class='flex items-start'>
                <span class='text-dark-accent mr-2'>✓</span>
                <span>Hourly booking (1-8 hours)</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Reservation Details -->
        <div class='bg-white rounded-lg shadow-lg p-8 md:p-12'>
          <h3
            class='text-3xl font-agrandir font-light mb-6 text-dark-accent text-center'>
            How to Reserve
          </h3>
          <div class='space-y-6 max-w-2xl mx-auto'>
            <div class='flex items-start gap-4'>
              <div
                class='flex-shrink-0 w-10 h-10 bg-dark-accent text-white rounded-full flex items-center justify-center font-agrandir text-lg'>
                1
              </div>
              <div>
                <h4 class='font-agrandir text-lg mb-2 text-dark-accent'>
                  Click the WhatsApp button below
                </h4>
                <p class='text-gray-600 font-inter'>
                  This will open a chat with our team on WhatsApp
                </p>
              </div>
            </div>

            <div class='flex items-start gap-4'>
              <div
                class='flex-shrink-0 w-10 h-10 bg-dark-accent text-white rounded-full flex items-center justify-center font-agrandir text-lg'>
                2
              </div>
              <div>
                <h4 class='font-agrandir text-lg mb-2 text-dark-accent'>
                  Share your reservation details
                </h4>
                <p class='text-gray-600 font-inter'>
                  Tell us your preferred date, time, type of reservation (table
                  or gaming), and number of people
                </p>
              </div>
            </div>

            <div class='flex items-start gap-4'>
              <div
                class='flex-shrink-0 w-10 h-10 bg-dark-accent text-white rounded-full flex items-center justify-center font-agrandir text-lg'>
                3
              </div>
              <div>
                <h4 class='font-agrandir text-lg mb-2 text-dark-accent'>
                  Get instant confirmation
                </h4>
                <p class='text-gray-600 font-inter'>
                  Our team will confirm your reservation and answer any
                  questions you may have
                </p>
              </div>
            </div>
          </div>

          <!-- WhatsApp Button -->
          <div class='text-center mt-12'>
            <a
              href={whatsappUrl}
              target='_blank'
              rel='noopener noreferrer'
              class='inline-flex items-center gap-3 px-10 py-5 bg-[#25D366] text-white font-agrandir text-xl rounded-lg hover:bg-[#128C7E] transition-all hover:scale-105 active:scale-95 shadow-lg'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-7 h-7'>
                <path
                  d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z'
                ></path>
              </svg>
              <span>Reserve on WhatsApp</span>
            </a>
            <p class='text-gray-500 font-inter text-sm mt-4'>
              Available 7 days a week, 9 AM - 11 PM
            </p>
          </div>
        </div>

        <!-- Policies -->
        <div class='bg-white rounded-lg shadow-md p-8'>
          <h3 class='text-2xl font-agrandir font-light mb-6 text-dark-accent'>
            Reservation Policy
          </h3>
          <div class='space-y-4 text-gray-600 font-inter'>
            <div class='flex items-start gap-3'>
              <span class='text-dark-accent text-xl'>•</span>
              <p>
                <strong class='text-dark-accent'>Confirmation:</strong> All reservations
                must be confirmed by our team via WhatsApp
              </p>
            </div>
            <div class='flex items-start gap-3'>
              <span class='text-dark-accent text-xl'>•</span>
              <p>
                <strong class='text-dark-accent'>Arrival Time:</strong> Please arrive
                within 15 minutes of your reservation time
              </p>
            </div>
            <div class='flex items-start gap-3'>
              <span class='text-dark-accent text-xl'>•</span>
              <p>
                <strong class='text-dark-accent'>Gaming Sessions:</strong>
                PlayStation bookings are charged per hour with a minimum 1-hour booking
              </p>
            </div>
            <div class='flex items-start gap-3'>
              <span class='text-dark-accent text-xl'>•</span>
              <p>
                <strong class='text-dark-accent'>Cancellations:</strong> Please inform
                us at least 2 hours in advance for any changes or cancellations
              </p>
            </div>
            <div class='flex items-start gap-3'>
              <span class='text-dark-accent text-xl'>•</span>
              <p>
                <strong class='text-dark-accent'>Group Bookings:</strong> For parties
                of 10 or more, advance notice of 24 hours is recommended
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom Navigation -->
    <nav
      class='bottom-navigation flex w-full h-16 px-4 justify-between items-center shrink-0 bg-dark-accent'>
      <a
        href='/'
        class='back-button flex h-8 px-0.5 justify-center items-center rounded-2xl'>
        <svg
          width='40'
          height='32'
          viewBox='0 0 40 32'
          fill='none'
          xmlns='http://www.w3.org/2000/svg'>
          <path
            d='M1.29289 15.2929C0.902369 15.6834 0.902369 16.3166 1.29289 16.7071L7.65685 23.0711C8.04738 23.4616 8.68054 23.4616 9.07107 23.0711C9.46159 22.6805 9.46159 22.0474 9.07107 21.6569L3.41421 16L9.07107 10.3431C9.46159 9.95262 9.46159 9.31946 9.07107 8.92893C8.68054 8.53841 8.04738 8.53841 7.65685 8.92893L1.29289 15.2929ZM38 17C38.5523 17 39 16.5523 39 16C39 15.4477 38.5523 15 38 15V16V17ZM2 16L2 17L38 17V16V15L2 15L2 16Z'
            fill='white'></path>
        </svg>
      </a>
    </nav>
  </main>
</IndexLayout>

<style>
  .reservation-section {
    scroll-behavior: smooth;
  }

  @media (max-width: 768px) {
    .reservation-card {
      padding: 1.5rem;
    }
  }
</style>
